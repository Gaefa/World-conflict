{
  "name": "conflict-game-desktop",
  "version": "0.1.0",
  "description": "Conflict.Game - Geopolitical MMO Strategy",
  "author": "Conflict.Game Team",
  "repository": "https://github.com/Gaefa/World-conflict",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:server": "cd ../server && npm run build",
    "build:web": "cd ../web && npx next build",
    "build:all": "npm run build:server && npm run build:web",
    "dist:mac": "npm run build:all && electron-builder --mac --publish never",
    "dist:win": "npm run build:all && electron-builder --win --publish never",
    "dist": "npm run build:all && electron-builder --mac --win --publish never"
  },
  "build": {
    "appId": "game.conflict.app",
    "productName": "Conflict.Game",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../server/package.json",
        "to": "server/package.json"
      },
      {
        "from": "../../node_modules",
        "to": "server/node_modules",
        "filter": [
          "fastify/**", "@fastify/**", "ws/**", "pino/**", "zod/**",
          "drizzle-orm/**", "postgres/**", "nanoid/**",
          "fast-json-stringify/**", "ajv/**", "find-my-way/**",
          "abstract-logging/**", "avvio/**", "fast-content-type-parse/**",
          "fast-querystring/**", "forwarded/**", "light-my-request/**",
          "on-exit-leak-free/**", "pino-std-serializers/**", "process-warning/**",
          "proxy-addr/**", "rfdc/**", "secure-json-parse/**",
          "sonic-boom/**", "thread-stream/**", "toad-cache/**",
          "ret/**", "safe-regex2/**", "ipaddr.js/**",
          "atomic-sleep/**", "fast-redact/**", "quick-format-unescaped/**",
          "real-require/**"
        ]
      },
      {
        "from": "../../packages/shared-types",
        "to": "server/node_modules/@conflict-game/shared-types",
        "filter": ["src/**", "dist/**", "package.json", "tsconfig.json"]
      },
      {
        "from": "../../packages/game-logic",
        "to": "server/node_modules/@conflict-game/game-logic",
        "filter": ["src/**", "dist/**", "package.json", "tsconfig.json"]
      },
      {
        "from": "../../packages/utils",
        "to": "server/node_modules/@conflict-game/utils",
        "filter": ["src/**", "dist/**", "package.json", "tsconfig.json"]
      },
      {
        "from": "../web/.next/standalone",
        "to": "web",
        "filter": ["**/*"]
      },
      {
        "from": "../web/.next/static",
        "to": "web/apps/web/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "../web/public",
        "to": "web/apps/web/public",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg"],
      "icon": null,
      "category": "public.app-category.games",
      "identity": null
    },
    "win": {
      "target": ["nsis"],
      "icon": null
    },
    "dmg": {
      "title": "Conflict.Game"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^26.0.0"
  }
}
