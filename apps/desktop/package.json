{
  "name": "conflict-game-desktop",
  "version": "0.1.0",
  "description": "Conflict.Game - Geopolitical MMO Strategy",
  "author": "Conflict.Game Team",
  "repository": "https://github.com/Gaefa/World-conflict",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:server": "cd ../server && npm run build",
    "build:web": "cd ../web && npx next build",
    "build:all": "npm run build:server && npm run build:web",
    "dist:mac": "npm run build:all && electron-builder --mac --publish never",
    "dist:win": "npm run build:all && electron-builder --win --publish never",
    "dist": "npm run build:all && electron-builder --mac --win --publish never"
  },
  "build": {
    "appId": "game.conflict.app",
    "productName": "Conflict.Game",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/out",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": null,
      "category": "public.app-category.games",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null
    },
    "dmg": {
      "title": "Conflict.Game",
      "contents": [
        { "x": 130, "y": 150, "type": "file" },
        { "x": 410, "y": 150, "type": "link", "path": "/Applications" },
        { "x": 270, "y": 380, "type": "file", "path": "Open Anyway.command" }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "26.8.1"
  }
}
